{{ 'style.css' | asset_url | stylesheet_tag }}

<div class="leopard-page">
  <nav class="text-shadow">
    <a href="/" class="logo-link">
      <img class="logo unselectable" src="{{ 'logo.png' | asset_url }}" alt="Reo logo">
    </a>
  </nav>

  <main class="item-main">
    <div class="shop-item-box">
      <div class="l">
        <p class="species-name text-shadow">Ursus maritimus</p>
        <div class="product-showcase">
          <div class="item-frame">
            <img
              class="showcase-main popout-hover"
              src="{{ 'polar-bear-cropped.png' | asset_url }}"
              alt="Polar Bear magnet artwork"
            >
          </div>
          <div class="showcase-thumbs" role="tablist" aria-label="Product image selector">
            <button class="showcase-thumb is-active" type="button" data-src="{{ 'polar-bear-cropped.png' | asset_url }}" data-alt="Polar Bear magnet artwork">
              <img src="{{ 'polar-bear-cropped.png' | asset_url }}" alt="Polar Bear thumbnail cropped">
            </button>
            <button class="showcase-thumb" type="button" data-src="{{ 'logo.png' | asset_url }}" data-alt="Polar Bear full artwork">
              <img src="{{ 'logo.png' | asset_url }}" alt="Polar Bear thumbnail full">
            </button>
          </div>
        </div>
      </div>

      <div class="r">
        <h2 class="item-category">Magnet Set</h2>
        <h1 class="item-title text-shadow">Polar Bear</h1>
        <p>
          Gloria is a polar bear, one of the largest land carnivores on Earth!
          But as sea ice melts, life gets harder and harder for them, with only around 17,000 polar bears left in the wild.
          <br><br>
          This set includes:
        </p>
        <ul>
          <li>1 Gloria magnet</li>
          <li>1 postcard from Gloria</li>
          <li>1 extra surprise: either a sticker or a clay figurine!</li>
        </ul>
        <p>
          40% of profits from this product will go directly to animal conservation efforts. 
        </p>
        <h2 class="item-price text-shadow">$5.00</h2>

        <div class="product-buy-box">
            {% form 'product', product, id: 'product-form' %}
                
                <input
                    type="hidden"
                    name="id"
                    value="{{ product.selected_or_first_available_variant.id }}"
                >

                <label for="quantity">Quantity</label>
                <input
                    type="number"
                    id="quantity"
                    name="quantity"
                    value="1"
                    min="1"
                >

                {{ form | payment_button }}

            {% endform %}
        </div>
      </div>
    </div>
  </main>

  <footer id="contact">
    <div class="l">
        <p>
            We acknowledge that the land on which we operate is Treaty 6 territory and a traditional meeting ground and home for many Indigenous peoples.
        </p>
    </div>
    <div class="r">
        <a href="https://www.instagram.com/stickwithreo/" target="_blank">
        
            <img src="{{ 'instagram-logo.svg' | asset_url }}" class="link-logo insta unselectable">
        </a>
        <a href="mailto:reo.ja.team@gmail.com" target="_blank">
            <img src="{{ 'email-icon.svg' | asset_url }}" class="link-logo email unselectable">
        </a>
    </div>
</footer>
</div>

<script type="module" src="{{ 'main2.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Polar-Bear",
  "settings": []
}
{% endschema %}
